<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginTop="24dp"
    android:background="@color/bg_gray">

    <!-- Custom Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarBmi"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Theo Dõi Cân Nặng &amp; BMI"
        app:titleTextColor="@color/white"
        android:layout_marginTop="16dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Input Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cập Nhật Chỉ Số Cơ Thể"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginRight="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chiều cao (cm)"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:textSize="12sp"/>
                        <EditText
                            android:id="@+id/edHeight"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:background="@drawable/bg_input"
                            android:paddingLeft="12dp"
                            android:layout_marginTop="4dp"
                            android:inputType="numberDecimal"
                            android:hint="cm"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cân nặng (kg)"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:textSize="12sp"/>
                        <EditText
                            android:id="@+id/edWeight"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:background="@drawable/bg_input"
                            android:paddingLeft="12dp"
                            android:layout_marginTop="4dp"
                            android:inputType="numberDecimal"
                            android:hint="kg"/>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button"
                    android:text="Tính toán &amp; Lưu lịch sử"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Result Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_card"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kết quả BMI gần nhất"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hãy nhập thông tin để tính"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- History Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch sử thay đổi thể trạng"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBmiHistory"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:background="@drawable/bg_rounded_card"
                android:padding="8dp"
                android:elevation="3dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>